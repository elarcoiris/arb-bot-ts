# Coinbase Advanced Trade API
# Create at: https://www.coinbase.com/settings/api
# Needs: "view" + "trade" permissions
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# Kraken API
# Create at: https://www.kraken.com/u/security/api
# Needs: "Query Funds" + "Create & Modify Orders" permissions
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# Binance API
# Create at: https://www.binance.com/en/my/settings/api-management
# Needs: "Enable Reading" + "Enable Spot & Margin Trading" permissions
# US users: use Binance.US instead and uncomment the override lines below
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Binance.US override (uncomment if you are a US-based user)
# BINANCE_BASE_URL=https://api.binance.us
# BINANCE_WS_URL=wss://stream.binance.us:9443

# Bot Settings
# Set to "true" to scan only - never place real orders
DRY_RUN=true

# Trading pairs to monitor (Coinbase format; bot auto-translates per exchange)
# Binance uses USDT pairs (BTCUSDT etc.) - the bot handles translation automatically
PAIRS=BTC-USD,ETH-USD,SOL-USD

# Minimum net profit percentage after all fees to trigger a trade (e.g. 0.15 = 0.15%)
# Combined taker fees: Binance 0.10% + Coinbase 0.60% = 0.70% breakeven (BN/CB legs)
#                      Binance 0.10% + Kraken   0.26% = 0.36% breakeven (BN/KR legs)
MIN_PROFIT_PCT=0.15

# Max USD to deploy per arbitrage leg
TRADE_SIZE_USD=500

# How often to poll prices when not using WebSocket (milliseconds)
POLL_INTERVAL_MS=3000

# Max seconds to wait for both legs to fill before cancelling
ORDER_TIMEOUT_SEC=10
